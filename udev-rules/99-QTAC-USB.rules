# Rules for the existing FTDI debug boards
ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6011", MODE:="666", PROGRAM="/bin/sh -c 'echo -n $id:1.2 > /sys/bus/usb/drivers/ftdi_sio/unbind'"
ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6011", MODE:="666", PROGRAM="/bin/sh -c 'echo -n $id:1.3 > /sys/bus/usb/drivers/ftdi_sio/unbind'"

ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6010", MODE:="666", PROGRAM="/bin/sh -c 'echo -n $id:1.2 > /sys/bus/usb/drivers/ftdi_sio/unbind'"
ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6010", MODE:="666", PROGRAM="/bin/sh -c 'echo -n $id:1.3 > /sys/bus/usb/drivers/ftdi_sio/unbind'"

# Rules for the Arduino BugHopper boards
ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6015" ATTRS{product}=="*[Bb]ug[Hh]opper", MODE:="666", PROGRAM="/bin/sh -c 'echo -n $id:1.0 > /sys/bus/usb/drivers/ftdi_sio/unbind'"

# Following rule provides access to use the USB endpoint
SUBSYSTEMS=="usb", ACTION=="add", MODE="0666", GROUP="dialout"